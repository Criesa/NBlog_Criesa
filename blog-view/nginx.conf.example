server {
    listen 80;
    server_name criesa.cn;
    root /home/nblog/view/dist;
    index index.html;

    location = /robots.txt {
        try_files $uri =404;
    }

    location = /sitemap.xml {
        try_files $uri =404;
    }

    # SEO 生成器的文章文件位于 /blog/{id}/index.html。
    # 必须先检查 $uri/index.html，避免文章请求回退到只有空壳的 SPA 首页。
    location / {
        try_files $uri/index.html $uri /index.html;
    }
}
